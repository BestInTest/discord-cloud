<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0 http://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>linux-x64</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>discord-cloud-${project.version}</baseDirectory>

    <dependencySets>
        <dependencySet>
            <outputDirectory>/</outputDirectory>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <includes>
                <include>bo.wii.discordcloud:gui</include>
            </includes>
            <outputFileNameMapping>discord-cloud-gui-${project.version}.${artifact.extension}</outputFileNameMapping>
        </dependencySet>

        <dependencySet>
            <outputDirectory>/</outputDirectory>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <includes>
                <include>bo.wii.discordcloud:core</include>
                <include>bo.wii.discordcloud:downloader</include>
                <include>bo.wii.discordcloud:uploader</include>
                <include>bo.wii.discordcloud:deleter</include>
                <include>bo.wii.discordcloud:server</include>
                <include>bo.wii.discordcloud:cli-renderer</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}-${artifact.version}.${artifact.extension}</outputFileNameMapping>
        </dependencySet>

        <dependencySet>
            <outputDirectory>/plugins</outputDirectory>
            <useProjectArtifact>false</useProjectArtifact>
            <useProjectAttachments>false</useProjectAttachments>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <includes>
                <include>bo.wii.discordcloud:thumbnail-provider-ffmpeg</include>
                <include>bo.wii.discordcloud:thumbnail-provider-image</include>
            </includes>
            <outputFileNameMapping>${artifact.artifactId}-${artifact.version}.${artifact.extension}</outputFileNameMapping>
        </dependencySet>
    </dependencySets>

    <fileSets>
        <fileSet>
            <directory>${project.build.directory}/ffmpeg/linux-x64</directory>
            <outputDirectory>/ffmpeg/linux-x64</outputDirectory>
            <fileMode>0755</fileMode>
            <includes>
                <include>ffmpeg</include>
                <include>ffprobe</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>${project.build.directory}/ffmpeg/linux-x64</directory>
            <outputDirectory>/ffmpeg/linux-x64</outputDirectory>
            <fileMode>0644</fileMode>
            <includes>
                <include>LICENSE.txt</include>
            </includes>
        </fileSet>
    </fileSets>
</assembly>
